{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CDM v6 FX Forward (SettlementPayout + TradeLot subset)",
  "type": "object",
  "additionalProperties": false,
  "required": ["trade"],
  "properties": {
    "trade": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tradeDate", "tradableProduct"],
      "properties": {
        "tradeDate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["value"],
          "properties": {
            "value": {"type": "string", "format": "date"}
          }
        },
        "tradeIdentifier": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["assignedIdentifier"],
            "properties": {
              "assignedIdentifier": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["identifier"],
                  "properties": {
                    "identifier": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["value"],
                      "properties": {
                        "value": {"type": "string"}
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "party": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["partyId", "name"],
            "properties": {
              "partyId": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["identifier"],
                  "properties": {
                    "identifier": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["value"],
                      "properties": {
                        "value": {"type": "string"}
                      }
                    }
                  }
                }
              },
              "name": {
                "type": "object",
                "additionalProperties": false,
                "required": ["value"],
                "properties": {
                  "value": {"type": ["string", "null"]}
                }
              }
            }
          }
        },
        "tradableProduct": {
          "type": "object",
          "additionalProperties": false,
          "required": ["product", "tradeLot"],
          "properties": {
            "product": {
              "type": "object",
              "additionalProperties": false,
              "required": ["nonTransferableProduct"],
              "properties": {
                "nonTransferableProduct": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["economicTerms"],
                  "properties": {
                    "economicTerms": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["payout"],
                      "properties": {
                        "payout": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["settlementPayout"],
                          "properties": {
                            "settlementPayout": {
                              "type": "array",
                              "minItems": 1,
                              "items": {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["settlementTerms"],
                                "properties": {
                                  "settlementTerms": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "required": ["settlementDate", "settlementType"],
                                    "properties": {
                                      "settlementDate": {
                                        "type": "object",
                                        "additionalProperties": false,
                                        "required": ["adjustableOrAdjustedDate"],
                                        "properties": {
                                          "adjustableOrAdjustedDate": {
                                            "type": "object",
                                            "additionalProperties": false,
                                            "required": ["unadjustedDate"],
                                            "properties": {
                                              "unadjustedDate": {
                                                "type": "object",
                                                "additionalProperties": false,
                                                "required": ["value"],
                                                "properties": {
                                                  "value": {"type": "string", "format": "date"}
                                                }
                                              }
                                            }
                                          }
                                        }
                                      },
                                      "settlementType": {
                                        "type": "string",
                                        "enum": [
                                          "SettlementTypeEnum.PHYSICAL",
                                          "SettlementTypeEnum.CASH",
                                          "SettlementTypeEnum.REGULAR"
                                        ]
                                      },
                                      "settlementCurrency": {
                                        "type": "object",
                                        "additionalProperties": false,
                                        "required": ["value"],
                                        "properties": {
                                          "value": {"type": "string"}
                                        }
                                      }
                                    }
                                  },
                                  "payerReceiver": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                      "payer": {"type": ["object", "null"]},
                                      "receiver": {"type": ["object", "null"]}
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "tradeLot": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["priceQuantity"],
                "properties": {
                  "priceQuantity": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["quantity"],
                      "properties": {
                        "price": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": ["value", "unit", "perUnitOf"],
                            "properties": {
                              "value": {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["value"],
                                "properties": {
                                  "value": {"type": "number"}
                                }
                              },
                              "unit": {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["currency"],
                                "properties": {
                                  "currency": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "required": ["value"],
                                    "properties": {
                                      "value": {"type": "string"}
                                    }
                                  }
                                }
                              },
                              "perUnitOf": {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["currency"],
                                "properties": {
                                  "currency": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "required": ["value"],
                                    "properties": {
                                      "value": {"type": "string"}
                                    }
                                  }
                                }
                              }
                            }
                          }
                        },
                        "quantity": {
                          "type": "array",
                          "minItems": 2,
                          "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": ["value", "unit"],
                            "properties": {
                              "value": {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["value"],
                                "properties": {
                                  "value": {"type": "number"}
                                }
                              },
                              "unit": {
                                "type": "object",
                                "additionalProperties": false,
                                "required": ["currency"],
                                "properties": {
                                  "currency": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "required": ["value"],
                                    "properties": {
                                      "value": {"type": "string"}
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
