{"ts_ms": 1774973624356, "tool": "lookup_cdm_schema", "chars": 3752, "compacted": "{\"type_name\": \"EconomicTerms\", \"schema_file\": \"cdm-product-template-EconomicTerms.schema.json\", \"java_class\": \"cdm.product.template.EconomicTerms\", \"java_package\": \"cdm.product.template\", \"description\": \" This class represents the full set of price-forming features associated with a contractual product: the payout component, the notional/quantity, the effective and termination date and the date adjustment provisions when applying uniformily across the payout components. This class also includes the legal provisions which have valuation implications: cancelable provision, extendible provision, early termination provision and extraordinary events specification.\", \"properties\": {\"effectiveDate\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableOrRelativeDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrRelativeDate\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setEffectiveDate\", \"description\": \"The first day of the terms of the trade. This day may be subject to adjustment in accordance with a business day convention.\"}, \"terminationDate\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableOrRelativeDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrRelativeDate\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setTerminationDate\", \"description\": \"The last day of the terms of the trade. This date may be subject to adjustments in accordance with the business day convention. It can also be specified in relation to another scheduled date (e.g. the last payment date).\"}, \"dateAdjustments\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-BusinessDayAdjustments.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessDayAdjustments\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setDateAdjustments\", \"description\": \"The business day adjustment convention when it applies across all the payout components. This specification of the business day convention and financial business centers is used for adjusting any calculation period date if it would otherwise fall on a day that is not a business day in the specified business center.\"}, \"payout\": {\"type\": \"array\", \"ref\": \"cdm-product-template-Payout.schema.json\", \"java_class\": \"cdm.product.template.Payout\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addPayout\", \"description\": \"The payout specifies the future cashflow computation methodology which characterizes a financial product.\"}, \"terminationProvision\": {\"type\": \"object\", \"ref\": \"cdm-product-template-TerminationProvision.schema.json\", \"java_class\": \"cdm.product.template.TerminationProvision\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setTerminationProvision\", \"description\": \"Contains optional provisions pertaining to the termination characteristics of a contract.\"}, \"calculationAgent\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-CalculationAgent.schema.json\", \"java_class\": \"cdm.observable.asset.CalculationAgent\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setCalculationAgent\", \"description\": \"The ISDA calculation agent responsible for performing duties as defined in the applicable product definitions.\"}, \"nonStandardisedTerms\": {\"type\": \"boolean\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setNonStandardisedTerms\", \"description\": \"Specifies, when boolean value is True, that additional economic terms exist that have not been included in the product representation.\"}, \"collateral\": {\"type\": \"object\", \"ref\": \"cdm-product-collateral-Collateral.schema.json\", \"java_class\": \"cdm.product.collateral.Collateral\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setCollateral\", \"description\": \"Represents the collateral obligations of a party.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973624357, "tool": "lookup_cdm_schema", "chars": 7245, "compacted": "{\"type_name\": \"ExerciseTerms\", \"schema_file\": \"cdm-product-template-ExerciseTerms.schema.json\", \"java_class\": \"cdm.product.template.ExerciseTerms\", \"java_package\": \"cdm.product.template\", \"description\": \"A class defining the exercise period for an option together with any rules governing the notional amount of the underlying which can be exercised on any given exercise date and any associated exercise fees.\", \"properties\": {\"style\": {\"type\": \"object\", \"ref\": \"cdm-product-template-OptionExerciseStyleEnum.schema.json\", \"java_class\": \"cdm.product.template.OptionExerciseStyleEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setStyle\", \"description\": \"Whether the option has a single exercise (european), multiple exercise dates (bermuda), or a continuous range of exercise (american).\"}, \"commencementDate\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableOrRelativeDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrRelativeDate\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setCommencementDate\", \"description\": \"The first day of the exercise period for an American style option.\"}, \"exerciseDates\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableOrRelativeDates.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrRelativeDates\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setExerciseDates\", \"description\": \"The dates that define the Bermuda option exercise dates and the expiration date. The last specified date is assumed to be the expiration date. The dates can either be specified as a series of explicit dates and associated adjustments or as a series of dates defined relative to another schedule of dates, for example, the calculation period start dates. Where a relative series of dates are defined the first and last possible exercise dates can be separately specified.\"}, \"expirationDate\": {\"type\": \"array\", \"ref\": \"cdm-base-datetime-AdjustableOrRelativeDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrRelativeDate\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addExpirationDate\", \"description\": \"The last day within an exercise period for an American style option. For a European style option it is the only day within the exercise period.\"}, \"relevantUnderlyingDate\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableOrRelativeDates.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrRelativeDates\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setRelevantUnderlyingDate\", \"description\": \"The effective date on the underlying product if the option is exercised.  For example, for a swaption it is the swap effective date, for an option on an FX spot or forward it is the value date for settlement, and in an extendible/cancelable provision it is the swap termination date, which is the date on which the termination is effective.'\"}, \"earliestExerciseTime\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-BusinessCenterTime.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessCenterTime\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setEarliestExerciseTime\", \"description\": \"The earliest time at which notice of exercise can be given by the buyer to the seller (or seller's agent) to, and including, the expiration date.\"}, \"latestExerciseTime\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-BusinessCenterTime.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessCenterTime\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setLatestExerciseTime\", \"description\": \"For a Bermuda or American style option, the latest time on an exercise business day (excluding the expiration date) within the exercise period that notice can be given by the buyer to the seller or seller's agent. Notice of exercise given after this time will be deemed to have been given on the next exercise business day.\"}, \"expirationTime\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-BusinessCenterTime.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessCenterTime\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setExpirationTime\", \"description\": \"The latest time for exercise on expirationDate. It is made mandatory given that for all option styles, this field is required.\"}, \"expirationTimeType\": {\"type\": \"object\", \"ref\": \"cdm-product-template-ExpirationTimeTypeEnum.schema.json\", \"java_class\": \"cdm.product.template.ExpirationTimeTypeEnum\", \"required\": true, \"is_array\": false, \"setter_hint\": \"setExpirationTimeType\", \"description\": \"The time of day at which the equity option expires, for example the official closing time of the exchange.\"}, \"multipleExercise\": {\"type\": \"object\", \"ref\": \"cdm-product-template-MultipleExercise.schema.json\", \"java_class\": \"cdm.product.template.MultipleExercise\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setMultipleExercise\", \"description\": \"As defined in the 2000 ISDA Definitions, Section 12.4. Multiple Exercise, the buyer of the option has the right to exercise all or less than all the unexercised notional amount of the underlying swap on one or more days in the exercise period, but on any such day may not exercise less than the minimum notional amount or more that the maximum notional amount, and if an integral multiple amount is specified, the notional amount exercised must be equal to, or be an integral multiple of, the integral multiple amount.\"}, \"exerciseFeeSchedule\": {\"type\": \"object\", \"ref\": \"cdm-product-template-ExerciseFeeSchedule.schema.json\", \"java_class\": \"cdm.product.template.ExerciseFeeSchedule\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setExerciseFeeSchedule\", \"description\": \"The fees associated with an exercise date. The fees are conditional on the exercise occurring. The fees can be specified as actual currency amounts or as percentages of the notional amount being exercised.\"}, \"exerciseProcedure\": {\"type\": \"object\", \"ref\": \"cdm-product-template-ExerciseProcedure.schema.json\", \"java_class\": \"cdm.product.template.ExerciseProcedure\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setExerciseProcedure\", \"description\": \"The set of parameters defining the procedure associated with the exercise, e.g. manual exercise.\"}, \"exerciseFee\": {\"type\": \"object\", \"ref\": \"cdm-product-template-ExerciseFee.schema.json\", \"java_class\": \"cdm.product.template.ExerciseFee\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setExerciseFee\", \"description\": \"A fee to be paid on exercise. This could be represented as an amount or a rate and notional reference on which to apply the rate.\"}, \"partialExercise\": {\"type\": \"object\", \"ref\": \"cdm-product-template-PartialExercise.schema.json\", \"java_class\": \"cdm.product.template.PartialExercise\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setPartialExercise\", \"description\": \"As defined in the 2000 ISDA Definitions, Section 12.3. Partial Exercise, the buyer of the option has the right to exercise all or less than all the notional amount of the underlying swap on the expiration date, but may not exercise less than the minimum notional amount, and if an integral multiple amount is specified, the notional amount exercised must be equal to, or be an integral multiple of, the integral multiple amount.\"}}, \"required_fields\": [\"expirationTimeType\"]}"}
{"ts_ms": 1774973624358, "tool": "lookup_cdm_schema", "chars": 1822, "compacted": "{\"type_name\": \"OptionStrike\", \"schema_file\": \"cdm-product-template-OptionStrike.schema.json\", \"java_class\": \"cdm.product.template.OptionStrike\", \"java_package\": \"cdm.product.template\", \"description\": \"Defines the strike price of an option.\", \"properties\": {\"strikePrice\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-Price.schema.json\", \"java_class\": \"cdm.observable.asset.Price\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setStrikePrice\", \"description\": \"Defines the strike of an option in the form of a price that could be a cash price, interestRate, or other types.\"}, \"strikeReference\": {\"type\": \"object\", \"ref\": \"cdm-product-asset-metafields-ReferenceWithMetaFixedRateSpecification.schema.json\", \"java_class\": \"cdm.product.asset.metafields.ReferenceWithMetaFixedRateSpecification\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setStrikeReference\", \"description\": \"Defines the strike of an option in reference to the spread of the underlying swap (typical practice in the case of an option on a credit single name swaps).\"}, \"referenceSwapCurve\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-ReferenceSwapCurve.schema.json\", \"java_class\": \"cdm.observable.asset.ReferenceSwapCurve\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setReferenceSwapCurve\", \"description\": \"Defines the strike of an option when expressed by reference to a swap curve (Typically the case for a convertible bond option).\"}, \"averagingStrikeFeature\": {\"type\": \"object\", \"ref\": \"cdm-product-template-AveragingStrikeFeature.schema.json\", \"java_class\": \"cdm.product.template.AveragingStrikeFeature\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAveragingStrikeFeature\", \"description\": \"Defines an  option strike that is calculated from an average of observed market prices.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973624359, "tool": "lookup_cdm_schema", "chars": 4170, "compacted": "{\"type_name\": \"SettlementTerms\", \"schema_file\": \"cdm-product-common-settlement-SettlementTerms.schema.json\", \"java_class\": \"cdm.product.common.settlement.SettlementTerms\", \"java_package\": \"cdm.product.common.settlement\", \"description\": \"Specifies the settlement terms, which can either be cash, physical, or fx-based cash-settlement. This class can be used for the settlement of options and forwards, cash transactions (e.g. securities or foreign exchange), or in case of credit event.\", \"properties\": {\"settlementType\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-SettlementTypeEnum.schema.json\", \"java_class\": \"cdm.product.common.settlement.SettlementTypeEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setSettlementType\", \"description\": \"Whether the settlement will be cash, physical, by election, ...\"}, \"transferSettlementType\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-TransferSettlementEnum.schema.json\", \"java_class\": \"cdm.product.common.settlement.TransferSettlementEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setTransferSettlementType\", \"description\": \"The qualification as to how the transfer will settle, e.g. a DvP settlement.\"}, \"settlementCurrency\": {\"type\": \"object\", \"ref\": \"com-rosetta-model-metafields-FieldWithMetaString.schema.json\", \"java_class\": \"com.rosetta.model.metafields.FieldWithMetaString\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setSettlementCurrency\", \"description\": \"The settlement currency is to be specified when the Settlement Amount cannot be known in advance. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes.\"}, \"settlementDate\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-SettlementDate.schema.json\", \"java_class\": \"cdm.product.common.settlement.SettlementDate\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setSettlementDate\", \"description\": \"The date on which the settlement amount will be paid, subject to adjustment in accordance with any applicable business day convention. This component would not be present for a mandatory early termination provision where the cash settlement payment date is the mandatory early termination date.\"}, \"settlementCentre\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-SettlementCentreEnum.schema.json\", \"java_class\": \"cdm.product.common.settlement.SettlementCentreEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setSettlementCentre\", \"description\": \"Optional settlement centre as an enumerated list: Euroclear, Clearstream.\"}, \"settlementProvision\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-SettlementProvision.schema.json\", \"java_class\": \"cdm.product.common.settlement.SettlementProvision\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setSettlementProvision\", \"description\": \"Optionally defines the parameters that regulate a settlement.\"}, \"standardSettlementStyle\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-StandardSettlementStyleEnum.schema.json\", \"java_class\": \"cdm.product.common.settlement.StandardSettlementStyleEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setStandardSettlementStyle\", \"description\": \"Settlement Style.\"}, \"cashSettlementTerms\": {\"type\": \"array\", \"ref\": \"cdm-product-common-settlement-CashSettlementTerms.schema.json\", \"java_class\": \"cdm.product.common.settlement.CashSettlementTerms\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addCashSettlementTerms\", \"description\": \"Specifies the parameters associated with the cash settlement procedure.\"}, \"physicalSettlementTerms\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-PhysicalSettlementTerms.schema.json\", \"java_class\": \"cdm.product.common.settlement.PhysicalSettlementTerms\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setPhysicalSettlementTerms\", \"description\": \"Specifies the physical settlement terms which apply to the transaction.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973624360, "tool": "lookup_cdm_schema", "chars": 1214, "compacted": "{\"type_name\": \"Underlier\", \"schema_file\": \"cdm-product-template-Underlier.schema.json\", \"java_class\": \"cdm.product.template.Underlier\", \"java_package\": \"cdm.product.template\", \"description\": \"The underlying financial product that will be physically or cash settled, which can be of any type, eg an asset such as cash or a security, a product, or the cash settlement of an index rate.  Conditions are usually applied when used in a data type, such as a payout, to ensure this aligns with the use case.\", \"properties\": {\"Observable\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-metafields-ReferenceWithMetaObservable.schema.json\", \"java_class\": \"cdm.observable.asset.metafields.ReferenceWithMetaObservable\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setObservable\", \"description\": \"Specifies the object to be observed for a price, it could be an asset or a reference.\"}, \"Product\": {\"type\": \"object\", \"ref\": \"cdm-product-template-Product.schema.json\", \"java_class\": \"cdm.product.template.Product\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setProduct\", \"description\": \"Enables either a TransferableProduct or a NonTransferableProduct to be used in an underlier.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973624361, "tool": "lookup_cdm_schema", "chars": 1313, "compacted": "{\"type_name\": \"Observable\", \"schema_file\": \"cdm-observable-asset-Observable.schema.json\", \"java_class\": \"cdm.observable.asset.Observable\", \"java_package\": \"cdm.observable.asset\", \"description\": \"Specifies the object to be observed for a price, it could be an asset or a reference.\", \"properties\": {\"Asset\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-Asset.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.Asset\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAsset\", \"description\": \"The object to be observed is an Asset, ie something that can be owned and transferred in the financial markets.\"}, \"Basket\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-Basket.schema.json\", \"java_class\": \"cdm.observable.asset.Basket\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setBasket\", \"description\": \"The object to be observed is a Basket, ie a collection of Observables with an identifier and optional weightings.\"}, \"Index\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-Index.schema.json\", \"java_class\": \"cdm.observable.asset.Index\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setIndex\", \"description\": \"The object to be observed is an Index, ie an observable computed on the prices, rates or valuations of a number of assets.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973624362, "tool": "lookup_cdm_schema", "chars": 1779, "compacted": "{\"type_name\": \"Asset\", \"schema_file\": \"cdm-base-staticdata-asset-common-Asset.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.Asset\", \"java_package\": \"cdm.base.staticdata.asset.common\", \"description\": \"An Asset is defined as something that can be owned and transferred in the financial markets. As a choice data type, one and only one of the attributes must be used.\", \"properties\": {\"Cash\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-Cash.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.Cash\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setCash\", \"description\": \"An Asset that consists solely of a monetary holding in a currency.\"}, \"Commodity\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-Commodity.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.Commodity\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setCommodity\", \"description\": \"An Asset comprised of raw or refined materials or agricultural products, eg gold, oil or wheat.\"}, \"DigitalAsset\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-DigitalAsset.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.DigitalAsset\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setDigitalAsset\", \"description\": \"An Asset that exists only in digital form, eg Bitcoin or Ethereum; excludes the digital representation of other Assets.\"}, \"Instrument\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-Instrument.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.Instrument\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setInstrument\", \"description\": \"An asset that is issued by one party to one or more others; Instrument is also a choice data type.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973624363, "tool": "lookup_cdm_schema", "chars": 3138, "compacted": "{\"type_name\": \"Security\", \"schema_file\": \"cdm-base-staticdata-asset-common-Security.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.Security\", \"java_package\": \"cdm.base.staticdata.asset.common\", \"description\": \"Identifies a security by referencing an identifier and by specifying the sector.\", \"properties\": {\"identifier\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-asset-common-AssetIdentifier.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.AssetIdentifier\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addIdentifier\", \"description\": \"Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type.\"}, \"taxonomy\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-asset-common-Taxonomy.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.Taxonomy\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addTaxonomy\", \"description\": \"Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object.\"}, \"isExchangeListed\": {\"type\": \"boolean\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setIsExchangeListed\", \"description\": \"Defines whether the Asset is listed on a public exchange.\"}, \"exchange\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-party-LegalEntity.schema.json\", \"java_class\": \"cdm.base.staticdata.party.LegalEntity\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setExchange\", \"description\": \"If the Asset is listed, defines the public exchange of the listing.\"}, \"relatedExchange\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-LegalEntity.schema.json\", \"java_class\": \"cdm.base.staticdata.party.LegalEntity\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addRelatedExchange\", \"description\": \"Provides the related Exchanges, if applicable.\"}, \"instrumentType\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-InstrumentTypeEnum.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.InstrumentTypeEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setInstrumentType\", \"description\": \"Identifies the type of an instrument using an enumerated list.\"}, \"debtType\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-DebtType.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.DebtType\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setDebtType\", \"description\": \"Identifies the type of debt and selected debt economics.\"}, \"equityType\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-EquityTypeEnum.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.EquityTypeEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setEquityType\", \"description\": \"Identifies the type of equity.\"}, \"fundType\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-asset-common-FundProductTypeEnum.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.FundProductTypeEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setFundType\", \"description\": \"Identifies the type of fund.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973637283, "tool": "lookup_cdm_schema", "chars": 3750, "compacted": "{\"type_name\": \"Payout\", \"schema_file\": \"cdm-product-template-Payout.schema.json\", \"java_class\": \"cdm.product.template.Payout\", \"java_package\": \"cdm.product.template\", \"description\": \"Represents the set of future cashflow methodologies in the form of specific payout data type(s) which result from the financial product.  Examples: a trade in a cash asset will use only a settlement payout; for derivatives, two interest rate payouts can be combined to specify an interest rate swap; one interest rate payout can be combined with a credit default payout to specify a credit default swap.\", \"properties\": {\"AssetPayout\": {\"type\": \"object\", \"ref\": \"cdm-product-template-AssetPayout.schema.json\", \"java_class\": \"cdm.product.template.AssetPayout\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAssetPayout\", \"description\": \"Defines the assets and movements in a security financing transaction.\"}, \"CommodityPayout\": {\"type\": \"object\", \"ref\": \"cdm-product-asset-CommodityPayout.schema.json\", \"java_class\": \"cdm.product.asset.CommodityPayout\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setCommodityPayout\", \"description\": \"Defines the payout for the floating leg of a Commodity Swap.\"}, \"CreditDefaultPayout\": {\"type\": \"object\", \"ref\": \"cdm-product-asset-CreditDefaultPayout.schema.json\", \"java_class\": \"cdm.product.asset.CreditDefaultPayout\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setCreditDefaultPayout\", \"description\": \"The credit default payout, which provides the details necessary for determining when a credit payout will be triggered as well as the parameters for calculating the payout and the settlement terms.\"}, \"FixedPricePayout\": {\"type\": \"object\", \"ref\": \"cdm-product-template-FixedPricePayout.schema.json\", \"java_class\": \"cdm.product.template.FixedPricePayout\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setFixedPricePayout\", \"description\": \"Defines a payout in which one or more payouts are defined as a fixed price.\"}, \"InterestRatePayout\": {\"type\": \"object\", \"ref\": \"cdm-product-asset-InterestRatePayout.schema.json\", \"java_class\": \"cdm.product.asset.InterestRatePayout\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setInterestRatePayout\", \"description\": \"All of the terms necessary to define and calculate a cash flow based on a fixed, a floating or an inflation index rate. The interest rate payout can be applied to interest rate swaps and FRA (which both have two associated interest rate payouts), credit default swaps (to represent the fee leg when subject to periodic payments) and equity swaps (to represent the funding leg).\"}, \"OptionPayout\": {\"type\": \"object\", \"ref\": \"cdm-product-template-OptionPayout.schema.json\", \"java_class\": \"cdm.product.template.OptionPayout\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setOptionPayout\", \"description\": \"The option payout.\"}, \"PerformancePayout\": {\"type\": \"object\", \"ref\": \"cdm-product-template-PerformancePayout.schema.json\", \"java_class\": \"cdm.product.template.PerformancePayout\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setPerformancePayout\", \"description\": \"The performance payout, which encompasses the equity price returns, dividend returns, volatility return, variance return and correlation provisions.\"}, \"SettlementPayout\": {\"type\": \"object\", \"ref\": \"cdm-product-template-SettlementPayout.schema.json\", \"java_class\": \"cdm.product.template.SettlementPayout\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setSettlementPayout\", \"description\": \"Represents a forward settling payout. The 'Underlier' attribute captures the underlying payout, which is settled according to the 'SettlementTerms' attribute. Both FX Spot and FX Forward should use this component.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973637284, "tool": "lookup_cdm_schema", "chars": 1476, "compacted": "{\"type_name\": \"TradeLot\", \"schema_file\": \"cdm-product-template-TradeLot.schema.json\", \"java_class\": \"cdm.product.template.TradeLot\", \"java_package\": \"cdm.product.template\", \"description\": \"Specifies the price and quantity of a trade lot, where the same product could be traded multiple times with the same counterparty but in different lots (at a different date, in a different quantity and at a different price). One trade lot combined with a product definition specifies the entire economics of a trade. The lifecycle mechanics of each such trade lot (e.g. cashflow payments) is independent of the other lots.\", \"properties\": {\"lotIdentifier\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-identifier-Identifier.schema.json\", \"java_class\": \"cdm.base.staticdata.identifier.Identifier\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addLotIdentifier\", \"description\": \"Specifies one or more identifiers for the lot, if any.\"}, \"priceQuantity\": {\"type\": \"array\", \"ref\": \"cdm-observable-asset-PriceQuantity.schema.json\", \"java_class\": \"cdm.observable.asset.PriceQuantity\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addPriceQuantity\", \"description\": \"Specifies the settlement characteristics of a trade lot: price, quantity, observable (optionally) and the settlement terms. This attribute has a multiple cardinality to allow to specify the price, quantity and observable of different legs in a single, composite product (e.g. a Swap).\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973637285, "tool": "lookup_cdm_schema", "chars": 2622, "compacted": "{\"type_name\": \"PriceQuantity\", \"schema_file\": \"cdm-observable-asset-PriceQuantity.schema.json\", \"java_class\": \"cdm.observable.asset.PriceQuantity\", \"java_package\": \"cdm.observable.asset\", \"description\": \"Defines a settlement as an exchange between two parties of a specified quantity of an asset (the quantity) against a specified quantity of another asset (the price). The settlement is optional and can be either cash or physical. The quantity can additionally be specified in terms of one or more currency amounts. In the case of non-cash products, the settlement of the price/quantity would not be specified here and instead would be delegated to the product mechanics, as parameterised by the price/quantity values.\", \"properties\": {\"price\": {\"type\": \"array\", \"ref\": \"cdm-observable-asset-metafields-FieldWithMetaPriceSchedule.schema.json\", \"java_class\": \"cdm.observable.asset.metafields.FieldWithMetaPriceSchedule\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addPrice\", \"description\": \"Specifies a price to be used for trade amounts and other purposes.\"}, \"quantity\": {\"type\": \"array\", \"ref\": \"cdm-base-math-metafields-FieldWithMetaNonNegativeQuantitySchedule.schema.json\", \"java_class\": \"cdm.base.math.metafields.FieldWithMetaNonNegativeQuantitySchedule\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addQuantity\", \"description\": \"Specifies a quantity to be associated with an event, for example a trade amount.\"}, \"observable\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-metafields-FieldWithMetaObservable.schema.json\", \"java_class\": \"cdm.observable.asset.metafields.FieldWithMetaObservable\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setObservable\", \"description\": \"Specifies the object to be observed for a price, it could be an asset or an index. The cardinality is optional as some quantity / price cases have no observable (e.g. a fixed rate in a given currency).\"}, \"effectiveDate\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableOrRelativeDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrRelativeDate\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setEffectiveDate\", \"description\": \"Specifies the date at which the price and quantity become effective. This day may be subject to adjustment in accordance with a business day convention, or could be specified as relative to a trade date, for instance. Optional cardinality, as the effective date is usually specified in the product definition, so it may only need to be specified as part of the PriceQuantity in an increase/decrease scenario for an existing trade.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973637286, "tool": "lookup_cdm_schema", "chars": 5093, "compacted": "{\"type_name\": \"ResolvablePriceQuantity\", \"schema_file\": \"cdm-product-common-settlement-ResolvablePriceQuantity.schema.json\", \"java_class\": \"cdm.product.common.settlement.ResolvablePriceQuantity\", \"java_package\": \"cdm.product.common.settlement\", \"description\": \"Generic class to specify the quantity for different payout legs in a contractual product, when that quantity can vary across payout legs or across time. A resolvable quantity can always be resolved into a single quantity from the quantity notation which has a corresponding asset identifier. In addition to the base case, where quantity is directly specified as a number as part of the quantity notation, the other use cases are: (i) quantity based on some pre-defined schedule (eg amortising notional), (ii) quantity based on some pre-defined events (eg resetting cross-currency notional), or quantity set as reference to another quantity (eg equity notional as no. securities x price).\", \"properties\": {\"resolvedQuantity\": {\"type\": \"object\", \"ref\": \"cdm-base-math-Quantity.schema.json\", \"java_class\": \"cdm.base.math.Quantity\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setResolvedQuantity\", \"description\": \"A product's quantity as a single, non-negative amount.  When specified as part of a product definition, this quantity attribute would not be set.  Instead it is specified on the quantity notation along with an asset identifier matching this payout's asset identifier.  This allows the quantity to be resolved for a payout leg, which can then be specified here for convenience during data processing.  There needs to be at least one resolvable quantity across payout legs of a product to define an anchor that other payout quantities can refer to.  This attribute is ignored when mapping existing FpML messages.\"}, \"quantitySchedule\": {\"type\": \"object\", \"ref\": \"cdm-base-math-metafields-ReferenceWithMetaNonNegativeQuantitySchedule.schema.json\", \"java_class\": \"cdm.base.math.metafields.ReferenceWithMetaNonNegativeQuantitySchedule\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setQuantitySchedule\", \"description\": \"A payout's quantity specified as a schedule, which may also contain a single value if that quantity is constant. There can only be a single quantity schedule applicable to a payout: e.g. the notional for an interest rate leg. The quantity must be specified outside of the payout in a PriceQuantity object and only referenced inside the payout using an address.\"}, \"quantityReference\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-metafields-ReferenceWithMetaResolvablePriceQuantity.schema.json\", \"java_class\": \"cdm.product.common.settlement.metafields.ReferenceWithMetaResolvablePriceQuantity\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setQuantityReference\", \"description\": \"Reference quantity when resolvable quantity is defined as relative to another (resolvable) quantity. A resolvable quantity needs to contain either an absolute quantity or a reference to another (resolvable) quantity. This requirement is captured by a choice rule on the class.\"}, \"quantityMultiplier\": {\"type\": \"object\", \"ref\": \"cdm-product-common-settlement-QuantityMultiplier.schema.json\", \"java_class\": \"cdm.product.common.settlement.QuantityMultiplier\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setQuantityMultiplier\", \"description\": \"Quantity multiplier is specified on top of a reference quantity and is used as a multiplying factor when resolving the quantity. A quantity multiplier can only exist when the resolvable quantity specifies a reference quantity.\"}, \"reset\": {\"type\": \"boolean\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setReset\", \"description\": \"Whether the quantity is resettable\"}, \"futureValueNotional\": {\"type\": \"object\", \"ref\": \"cdm-product-asset-FutureValueAmount.schema.json\", \"java_class\": \"cdm.product.asset.FutureValueAmount\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setFutureValueNotional\", \"description\": \"The future value notional is specific to BRL CDI swaps, and is specified alongside the notional amount. The value is calculated as follows: Future Value Notional = Notional Amount * (1 + Fixed Rate) ^ (Fixed Rate Day Count Fraction). The currency should always match that expressed in the notional schedule. The value date should match the adjusted termination date.\"}, \"priceSchedule\": {\"type\": \"array\", \"ref\": \"cdm-observable-asset-metafields-ReferenceWithMetaPriceSchedule.schema.json\", \"java_class\": \"cdm.observable.asset.metafields.ReferenceWithMetaPriceSchedule\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addPriceSchedule\", \"description\": \"A payout's price specified as a schedule, which may also contain a single value if that price is constant. There may be multiple prices specified for a single payout: e.g. a floating interest rate leg may specify a spread, a cap and/or floor and a multiplier. The price must be specified outside of the payout in a PriceQuantity object and only referenced inside the payout using an address.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973637288, "tool": "lookup_cdm_schema", "chars": 3117, "compacted": "{\"type_name\": \"Party\", \"schema_file\": \"cdm-base-staticdata-party-Party.schema.json\", \"java_class\": \"cdm.base.staticdata.party.Party\", \"java_package\": \"cdm.base.staticdata.party\", \"description\": \"A class to specify a party, without a qualification as to whether this party is a legal entity or a natural person, although the model provides the ability to associate a person (or set of persons) to a party, which use case would imply that such party would be a legal entity (even if not formally specified as such). \", \"properties\": {\"partyId\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-PartyIdentifier.schema.json\", \"java_class\": \"cdm.base.staticdata.party.PartyIdentifier\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addPartyId\", \"description\": \"The identifier associated with a party, e.g. the 20 digits LEI code.\"}, \"name\": {\"type\": \"object\", \"ref\": \"com-rosetta-model-metafields-FieldWithMetaString.schema.json\", \"java_class\": \"com.rosetta.model.metafields.FieldWithMetaString\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setName\", \"description\": \"The party name.\"}, \"businessUnit\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-BusinessUnit.schema.json\", \"java_class\": \"cdm.base.staticdata.party.BusinessUnit\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addBusinessUnit\", \"description\": \"Optional organization unit information used to describe the organization units (e.g. trading desks) involved in a transaction or business process, incl. the contact information (when relevant).\"}, \"person\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-NaturalPerson.schema.json\", \"java_class\": \"cdm.base.staticdata.party.NaturalPerson\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addPerson\", \"description\": \"The person(s) who might be associated with the party as part of the execution, contract or legal document.\"}, \"personRole\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-NaturalPersonRole.schema.json\", \"java_class\": \"cdm.base.staticdata.party.NaturalPersonRole\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addPersonRole\", \"description\": \"The role of the person(s) \"}, \"account\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-party-Account.schema.json\", \"java_class\": \"cdm.base.staticdata.party.Account\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAccount\", \"description\": \"The account that might be associated with the party. At most one account can be specified, as it is expected that this information is used in the context of a contract or legal document where only one account per party can be associated with such object.\"}, \"contactInformation\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-party-ContactInformation.schema.json\", \"java_class\": \"cdm.base.staticdata.party.ContactInformation\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setContactInformation\", \"description\": \"The postal/street address, telephone number, email address and/or web page. If the contact information is specific to the associated business unit(s) or person (s), it should be associated with those.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973637290, "tool": "lookup_cdm_schema", "chars": 1562, "compacted": "{\"type_name\": \"Counterparty\", \"schema_file\": \"cdm-base-staticdata-party-Counterparty.schema.json\", \"java_class\": \"cdm.base.staticdata.party.Counterparty\", \"java_package\": \"cdm.base.staticdata.party\", \"description\": \"Defines a counterparty enumerated value, e.g. Party1 or Party2, with an associated party reference. The product is agnostic to the actual parties to the transaction, with the party references abstracted away from the product definition and replaced by the CounterpartyEnum (e.g. values Party1 or Party2). The CounterpartyEnum can then be positioned in the product (e.g. to specify which counterparty is the payer, receiver etc) and this Counterparty type, which is positioned outside of the product definition, allows the CounterpartyEnum to be associated with an actual party reference.\", \"properties\": {\"role\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-party-CounterpartyRoleEnum.schema.json\", \"java_class\": \"cdm.base.staticdata.party.CounterpartyRoleEnum\", \"required\": true, \"is_array\": false, \"setter_hint\": \"setRole\", \"description\": \"Specifies the CounterpartyEnum, e.g. either Party1 or Party2, that is associated to the partyReference.\"}, \"partyReference\": {\"type\": \"object\", \"ref\": \"cdm-base-staticdata-party-metafields-ReferenceWithMetaParty.schema.json\", \"java_class\": \"cdm.base.staticdata.party.metafields.ReferenceWithMetaParty\", \"required\": true, \"is_array\": false, \"setter_hint\": \"setPartyReference\", \"description\": \"Specifies the party that is associated to the counterparty.\"}}, \"required_fields\": [\"partyReference\", \"role\"]}"}
