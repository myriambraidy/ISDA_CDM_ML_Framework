{"ts_ms": 1774973624354, "tool": "lookup_cdm_schema", "chars": 6802, "compacted": "{\"type_name\": \"Trade\", \"schema_file\": \"cdm-event-common-Trade.schema.json\", \"java_class\": \"cdm.event.common.Trade\", \"java_package\": \"cdm.event.common\", \"description\": \"Defines the output of a financial transaction between parties - a Business Event. A Trade impacts the financial position (i.e. the balance sheet) of involved parties.\", \"properties\": {\"product\": {\"type\": \"object\", \"ref\": \"cdm-product-template-NonTransferableProduct.schema.json\", \"java_class\": \"cdm.product.template.NonTransferableProduct\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setProduct\", \"description\": \"The underlying product to be included in a contract or execution.\"}, \"tradeLot\": {\"type\": \"array\", \"ref\": \"cdm-product-template-TradeLot.schema.json\", \"java_class\": \"cdm.product.template.TradeLot\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addTradeLot\", \"description\": \"Specifies the price, quantity and effective date of each trade lot, when the same product may be traded multiple times in different lots with the same counterparty. In a trade increase, a new trade lot is added to the list, with the corresponding effective date. In a trade decrease, the existing trade lot(s) are decreased of the corresponding quantity (and an unwind fee may have to be settled). The multiple cardinality and the ability to increase existing trades is used for Equity Swaps in particular.\"}, \"counterparty\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-Counterparty.schema.json\", \"java_class\": \"cdm.base.staticdata.party.Counterparty\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addCounterparty\", \"description\": \"Specifies the parties which are the two counterparties to the transaction.  The product is agnostic to the actual parties to the transaction, with the party references abstracted away from the product definition and replaced by the counterparty enum (e.g. CounterpartyEnum values Party1 or Party2). The counterparty enum can then be positioned in the product (e.g. to specify which counterparty is the payer, receiver etc) and this counterparties attribute, which is positioned outside of the product definition, allows the counterparty enum to be associated with an actual party reference.\"}, \"ancillaryParty\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-AncillaryParty.schema.json\", \"java_class\": \"cdm.base.staticdata.party.AncillaryParty\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addAncillaryParty\", \"description\": \"Specifies the parties with ancillary roles in the transaction. The product is agnostic to the actual parties involved in the transaction, with the party references abstracted away from the product definition and replaced by the AncillaryRoleEnum. The AncillaryRoleEnum can then be positioned in the product and this AncillaryParty type, which is positioned outside of the product definition, allows the AncillaryRoleEnum to be associated with an actual party reference.\"}, \"adjustment\": {\"type\": \"object\", \"ref\": \"cdm-product-common-NotionalAdjustmentEnum.schema.json\", \"java_class\": \"cdm.product.common.NotionalAdjustmentEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAdjustment\", \"description\": \"Specifies the conditions that govern the adjustment to the quantity of a product being traded: e.g. execution, portfolio rebalancing etc. It is typically used in the context of Equity Swaps.\"}, \"tradeIdentifier\": {\"type\": \"array\", \"ref\": \"cdm-event-common-TradeIdentifier.schema.json\", \"java_class\": \"cdm.event.common.TradeIdentifier\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addTradeIdentifier\", \"description\": \"Represents the identifier(s) that uniquely identify a trade for an identity issuer. A trade can include multiple identifiers, for example a trade that is reportable to both the CFTC and ESMA, and then has an associated USI (Unique Swap Identifier) UTI (Unique Trade Identifier).\"}, \"tradeDate\": {\"type\": \"object\", \"ref\": \"com-rosetta-model-metafields-FieldWithMetaString.schema.json\", \"java_class\": \"com.rosetta.model.metafields.FieldWithMetaString\", \"required\": true, \"is_array\": false, \"setter_hint\": \"setTradeDate\", \"description\": \"Specifies the date which the trade was agreed.\"}, \"tradeTime\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-metafields-FieldWithMetaTimeZone.schema.json\", \"java_class\": \"cdm.base.datetime.metafields.FieldWithMetaTimeZone\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setTradeTime\", \"description\": \"Denotes the trade time and timezone as agreed by the parties to the trade.\"}, \"party\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-Party.schema.json\", \"java_class\": \"cdm.base.staticdata.party.Party\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addParty\", \"description\": \"Represents the parties to the trade. The cardinality is optional to address the case where the trade is defined within a BusinessEvent data type, in which case the party is specified in BusinessEvent.\"}, \"partyRole\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-party-PartyRole.schema.json\", \"java_class\": \"cdm.base.staticdata.party.PartyRole\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addPartyRole\", \"description\": \"Represents the role each specified party takes in the trade. further to the principal roles, payer and receiver.\"}, \"executionDetails\": {\"type\": \"object\", \"ref\": \"cdm-event-common-ExecutionDetails.schema.json\", \"java_class\": \"cdm.event.common.ExecutionDetails\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setExecutionDetails\", \"description\": \"Represents information specific to trades that arose from executions.\"}, \"contractDetails\"