{"ts_ms": 1774973637292, "tool": "lookup_cdm_schema", "chars": 1671, "compacted": "{\"type_name\": \"NonTransferableProduct\", \"schema_file\": \"cdm-product-template-NonTransferableProduct.schema.json\", \"java_class\": \"cdm.product.template.NonTransferableProduct\", \"java_package\": \"cdm.product.template\", \"description\": \"A data type to specify the financial product's economic terms, alongside the product identification and product taxonomy. The non-transferable product data type represents a product that can be traded (as part of a TradableProduct) but cannot be transferred to others.  It is meant to be used across the pre-execution, execution and (as part of the Contract) post-execution lifecycle contexts.\", \"properties\": {\"identifier\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-asset-common-ProductIdentifier.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.ProductIdentifier\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addIdentifier\", \"description\": \"Comprises a identifier and a source to uniquely identify the nonTransferableProduct. \"}, \"taxonomy\": {\"type\": \"array\", \"ref\": \"cdm-base-staticdata-asset-common-ProductTaxonomy.schema.json\", \"java_class\": \"cdm.base.staticdata.asset.common.ProductTaxonomy\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addTaxonomy\", \"description\": \"Specifies the product taxonomy, which is composed of a taxonomy value and a taxonomy source.\"}, \"economicTerms\": {\"type\": \"object\", \"ref\": \"cdm-product-template-EconomicTerms.schema.json\", \"java_class\": \"cdm.product.template.EconomicTerms\", \"required\": true, \"is_array\": false, \"setter_hint\": \"setEconomicTerms\", \"description\": \"The price forming features, including payouts and provisions.\"}}, \"required_fields\": [\"economicTerms\"]}"}
{"ts_ms": 1774973648266, "tool": "lookup_cdm_schema", "chars": 3852, "compacted": "{\"type_name\": \"Price\", \"schema_file\": \"cdm-observable-asset-Price.schema.json\", \"java_class\": \"cdm.observable.asset.Price\", \"java_package\": \"cdm.observable.asset\", \"description\": \"Specifies a price as a single value to be associated to a financial product. This data type extends PriceSchedule and requires that only the amount value exists.\", \"properties\": {\"value\": {\"type\": \"number\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setValue\", \"description\": \"Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted.\"}, \"unit\": {\"type\": \"object\", \"ref\": \"cdm-base-math-UnitType.schema.json\", \"java_class\": \"cdm.base.math.UnitType\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setUnit\", \"description\": \"Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit).\"}, \"datedValue\": {\"type\": \"array\", \"ref\": \"cdm-base-math-DatedValue.schema.json\", \"java_class\": \"cdm.base.math.DatedValue\", \"required\": false, \"is_array\": true, \"setter_hint\": \"addDatedValue\", \"description\": \"A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value.\"}, \"perUnitOf\": {\"type\": \"object\", \"ref\": \"cdm-base-math-UnitType.schema.json\", \"java_class\": \"cdm.base.math.UnitType\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setPerUnitOf\", \"description\": \"Provides an attribute to define the unit of the thing being priced. For example, {amount, unitOfAmount, PerUnitOfAmount} = [10, EUR, Shares] = (10.00 EUR/SHARE) * (300,000 SHARES) = EUR 3,000,000.00 (Shares cancel out in the calculation).\"}, \"priceType\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-PriceTypeEnum.schema.json\", \"java_class\": \"cdm.observable.asset.PriceTypeEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setPriceType\", \"description\": \"Specifies the price type as an enumeration: interest rate, exchange rate, asset price etc. This attribute is mandatory so that prices can always be clasiffied according to their type. The price type implies some constraints on the price's units.\"}, \"priceExpression\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-PriceExpressionEnum.schema.json\", \"java_class\": \"cdm.observable.asset.PriceExpressionEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setPriceExpression\", \"description\": \"(Optionally) Specifies whether the price is expressed in absolute or percentage terms.\"}, \"composite\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-PriceComposite.schema.json\", \"java_class\": \"cdm.observable.asset.PriceComposite\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setComposite\", \"description\": \"(Optionally) Specifies the underlying price components if the price can be expressed as a composite: e.g. dirty price = clean price + accrued.\"}, \"arithmeticOperator\": {\"type\": \"object\", \"ref\": \"cdm-base-math-ArithmeticOperationEnum.schema.json\", \"java_class\": \"cdm.base.math.ArithmeticOperationEnum\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setArithmeticOperator\", \"description\": \"(Optionally) When the price is to be understood as an operator to apply to an observable, i.e. a spread, multiplier or min/max.\"}, \"cashPrice\": {\"type\": \"object\", \"ref\": \"cdm-observable-asset-CashPrice.schema.json\", \"java_class\": \"cdm.observable.asset.CashPrice\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setCashPrice\", \"description\": \"(Optionally when the price type is cash) Additional attributes that further define a cash price, e.g. what type of fee it is.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973648270, "tool": "lookup_cdm_schema", "chars": 4354, "compacted": "{\"type_name\": \"SettlementDate\", \"schema_file\": \"cdm-product-common-settlement-SettlementDate.schema.json\", \"java_class\": \"cdm.product.common.settlement.SettlementDate\", \"java_package\": \"cdm.product.common.settlement\", \"description\": \"A data defining the settlement date(s) for cash or physical settlement as either a set of explicit dates, together with applicable adjustments, or as a date relative to some other (anchor) date, or as any date in a range of contiguous business days. This data type provides a level of abstraction on top of the different legacy methods used to specify a settlement / payment date, which vary across product types, asset classes and delivery types.\", \"properties\": {\"adjustableOrRelativeDate\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableOrAdjustedOrRelativeDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrAdjustedOrRelativeDate\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAdjustableOrRelativeDate\", \"description\": \"A single settlement date subject to adjustment or specified as relative to another date (e.g. the trade date). This attribute was formerly part of 'SettlementTerms', which is now being harmonised to include a common 'SettlementDate', as inherited from 'SettlementBase'.\"}, \"valueDate\": {\"type\": \"string\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setValueDate\", \"description\": \"The settlement date for a forward settling product. For Foreign Exchange contracts, this represents a common settlement date between both currency legs. To specify different settlement dates for each currency leg, see the ForeignExchange class. This attribute was formerly part of 'SettlementTerms', which is now being harmonised to include a common 'SettlementDate', as inherited from 'SettlementBase'.\"}, \"adjustableDates\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableDates.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableDates\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAdjustableDates\", \"description\": \"A series of dates that shall be subject to adjustment if they would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date. This attributes was formerly part of 'CashSettlementPaymentDate' as included into 'OptionCashSettlement' (which is now merged into a unique 'CashSettlementTerms' data type.\"}, \"businessDateRange\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-BusinessDateRange.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessDateRange\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setBusinessDateRange\", \"description\": \"A range of contiguous business days. This attribute is meant to be merged with the 'settlementDate' at some future point once we refactor 'Date' to use a single complex type across the model. This attributes was formerly part of 'CashSettlementPaymentDate', as included into 'OptionCashSettlement' (which is now merged into a unique 'CashSettlementTerms' data type.\"}, \"cashSettlementBusinessDays\": {\"type\": \"integer\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setCashSettlementBusinessDays\", \"description\": \"The number of business days used in the determination of the cash settlement payment date. If a cash settlement amount is specified, the cash settlement payment date will be this number of business days following the calculation of the final price. If a cash settlement amount is not specified, the cash settlement payment date will be this number of business days after all conditions to settlement are satisfied. ISDA 2003 Term: Cash Settlement Date. This attribute was formerly part of 'CashSettlementTerms' as used for credit event settlement, which now includes a common 'SettlementDate' attribute.\"}, \"paymentDelay\": {\"type\": \"boolean\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setPaymentDelay\", \"description\": \"Applicable to CDS on MBS to specify whether payment delays are applicable to the fixed Amount. RMBS typically have a payment delay of 5 days between the coupon date of the reference obligation and the payment date of the synthetic swap. CMBS do not, on the other hand, with both payment dates being on the 25th of each month.\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973648272, "tool": "lookup_cdm_schema", "chars": 2102, "compacted": "{\"type_name\": \"AdjustableDate\", \"schema_file\": \"cdm-base-datetime-AdjustableDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableDate\", \"java_package\": \"cdm.base.datetime\", \"description\": \"A class for defining a date that shall be subject to adjustment if it would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date.\", \"properties\": {\"unadjustedDate\": {\"type\": \"string\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setUnadjustedDate\", \"description\": \"A date subject to adjustment. While in FpML this date is required, this cardinality constraint has been relaxed as part of the CDM in order to support the FRA representation, which effective and termination dates are specified in FpML as adjusted dates.\"}, \"dateAdjustments\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-BusinessDayAdjustments.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessDayAdjustments\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setDateAdjustments\", \"description\": \"The business day convention and financial business centers used for adjusting the date if it would otherwise fall on a day that is not a business date in the specified business centers.\"}, \"dateAdjustmentsReference\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-metafields-ReferenceWithMetaBusinessDayAdjustments.schema.json\", \"java_class\": \"cdm.base.datetime.metafields.ReferenceWithMetaBusinessDayAdjustments\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setDateAdjustmentsReference\", \"description\": \"A pointer style reference to date adjustments defined elsewhere in the document.\"}, \"adjustedDate\": {\"type\": \"object\", \"ref\": \"com-rosetta-model-metafields-FieldWithMetaString.schema.json\", \"java_class\": \"com.rosetta.model.metafields.FieldWithMetaString\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAdjustedDate\", \"description\": \"The date once the adjustment has been performed. (Note that this date may change if the business center holidays change).\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973648273, "tool": "lookup_cdm_schema", "chars": 1170, "compacted": "{\"type_name\": \"AdjustableOrRelativeDate\", \"schema_file\": \"cdm-base-datetime-AdjustableOrRelativeDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableOrRelativeDate\", \"java_package\": \"cdm.base.datetime\", \"description\": \"A class giving the choice between defining a date as an explicit date together with applicable adjustments or as relative to some other (anchor) date.\", \"properties\": {\"adjustableDate\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustableDate.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustableDate\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAdjustableDate\", \"description\": \"A date that shall be subject to adjustment if it would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date.\"}, \"relativeDate\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-AdjustedRelativeDateOffset.schema.json\", \"java_class\": \"cdm.base.datetime.AdjustedRelativeDateOffset\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setRelativeDate\", \"description\": \"A date specified as some offset to another date (the anchor date).\"}}, \"required_fields\": []}"}
{"ts_ms": 1774973648274, "tool": "lookup_cdm_schema", "chars": 1232, "compacted": "{\"type_name\": \"BusinessDayAdjustments\", \"schema_file\": \"cdm-base-datetime-BusinessDayAdjustments.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessDayAdjustments\", \"java_package\": \"cdm.base.datetime\", \"description\": \"A class defining the business day convention and financial business centers used for adjusting any relevant date if it would otherwise fall on a day that is not a business day in the specified business center.\", \"properties\": {\"businessDayConvention\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-BusinessDayConventionEnum.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessDayConventionEnum\", \"required\": true, \"is_array\": false, \"setter_hint\": \"setBusinessDayConvention\", \"description\": \"The convention for adjusting a date if it would otherwise fall on a day that is not a business day.\"}, \"businessCenters\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-BusinessCenters.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessCenters\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setBusinessCenters\", \"description\": \"The business center(s), specified either explicitly or by reference to those specified somewhere else in the instance document.\"}}, \"required_fields\": [\"businessDayConvention\"]}"}
{"ts_ms": 1774973648275, "tool": "lookup_cdm_schema", "chars": 1134, "compacted": "{\"type_name\": \"BusinessCenterTime\", \"schema_file\": \"cdm-base-datetime-BusinessCenterTime.schema.json\", \"java_class\": \"cdm.base.datetime.BusinessCenterTime\", \"java_package\": \"cdm.base.datetime\", \"description\": \"A class for defining a time with respect to a business day calendar location. For example, 11:00:00 GBLO.\", \"properties\": {\"hourMinuteTime\": {\"type\": \"string\", \"ref\": null, \"java_class\": null, \"required\": true, \"is_array\": false, \"setter_hint\": \"setHourMinuteTime\", \"description\": \"A time specified in hh:mm:ss format where the second component must be '00', e.g. 11am would be represented as 11:00:00.\"}, \"businessCenter\": {\"type\": \"object\", \"ref\": \"cdm-base-datetime-metafields-FieldWithMetaBusinessCenterEnum.schema.json\", \"java_class\": \"cdm.base.datetime.metafields.FieldWithMetaBusinessCenterEnum\", \"required\": true, \"is_array\": false, \"setter_hint\": \"setBusinessCenter\", \"description\": \"A code identifying a business day calendar location. A business day calendar location is drawn from the list identified by the business day calendar location enumeration.\"}}, \"required_fields\": [\"businessCenter\", \"hourMinuteTime\"]}"}
{"ts_ms": 1774973648276, "tool": "lookup_cdm_schema", "chars": 2753, "compacted": "{\"type_name\": \"ExerciseProcedure\", \"schema_file\": \"cdm-product-template-ExerciseProcedure.schema.json\", \"java_class\": \"cdm.product.template.ExerciseProcedure\", \"java_package\": \"cdm.product.template\", \"description\": \"A class describing how notice of exercise should be given. This can be either manual or automatic.\", \"properties\": {\"manualExercise\": {\"type\": \"object\", \"ref\": \"cdm-product-template-ManualExercise.schema.json\", \"java_class\": \"cdm.product.template.ManualExercise\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setManualExercise\", \"description\": \"Specifies that the notice of exercise must be given by the buyer to the seller or seller's agent.\"}, \"automaticExercise\": {\"type\": \"object\", \"ref\": \"cdm-product-template-AutomaticExercise.schema.json\", \"java_class\": \"cdm.product.template.AutomaticExercise\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setAutomaticExercise\", \"description\": \"If automatic is specified, then the notional amount of the underlying swap not previously exercised under the swaption will be automatically exercised at the expiration time on the expiration date if at such time the buyer is in-the-money, provided that the difference between the settlement rate and the fixed rate under the relevant underlying swap is not less than the specified threshold rate. The term in-the-money is assumed to have the meaning defining in the 2000 ISDA Definitions, Section 17.4 In-the-money.\"}, \"followUpConfirmation\": {\"type\": \"boolean\", \"ref\": null, \"java_class\": null, \"required\": true, \"is_array\": false, \"setter_hint\": \"setFollowUpConfirmation\", \"description\": \"A flag to indicate whether follow-up confirmation of exercise (written or electronic) is required following telephonic notice by the buyer to the seller or seller's agent.\"}, \"limitedRightToConfirm\": {\"type\": \"boolean\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setLimitedRightToConfirm\", \"description\": \"Has the meaning defined as part of the 1997 ISDA Government Bond Option Definitions, section 4.5 Limited Right to Confirm Exercise. If present, (i) the Seller may request the Buyer to confirm its intent if not done on or before the expiration time on the Expiration date (ii) specific rules will apply in relation to the settlement mode.\"}, \"splitTicket\": {\"type\": \"boolean\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setSplitTicket\", \"description\": \"Typically applicable to the physical settlement of bond and convertible bond options. If present, means that the party required to deliver the bonds will divide those to be delivered as notifying party desires to facilitate delivery obligations.\"}}, \"required_fields\": [\"followUpConfirmation\"]}"}
{"ts_ms": 1774973648277, "tool": "lookup_cdm_schema", "chars": 1395, "compacted": "{\"type_name\": \"ManualExercise\", \"schema_file\": \"cdm-product-template-ManualExercise.schema.json\", \"java_class\": \"cdm.product.template.ManualExercise\", \"java_package\": \"cdm.product.template\", \"description\": \"A class defining manual exercise, i.e. that the option buyer counterparty must give notice to the option seller of exercise.\", \"properties\": {\"exerciseNotice\": {\"type\": \"object\", \"ref\": \"cdm-product-template-ExerciseNotice.schema.json\", \"java_class\": \"cdm.product.template.ExerciseNotice\", \"required\": false, \"is_array\": false, \"setter_hint\": \"setExerciseNotice\", \"description\": \"Definition of the party to whom notice of exercise should be given.\"}, \"fallbackExercise\": {\"type\": \"boolean\", \"ref\": null, \"java_class\": null, \"required\": false, \"is_array\": false, \"setter_hint\": \"setFallbackExercise\", \"description\": \"If fallback exercise is specified then the notional amount of the underlying swap, not previously exercised under the swaption, will be automatically exercised at the expiration time on the expiration date if at such time the buyer is in-the-money, provided that the difference between the settlement rate and the fixed rate under the relevant underlying swap is not less than one tenth of a percentage point (0.10% or 0.001). The term in-the-money is assumed to have the meaning defined in the 2000 ISDA Definitions, Section 17.4. In-the-money.\"}}, \"required_fields\": []}"}
